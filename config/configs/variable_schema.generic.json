      "role": "candidate_cause"
    },
    "x2": {
      "kind": "numeric",
      "description": "Generic numeric variable 2",
      "role": "candidate_cause"
    },
    "x3": {
      "kind": "numeric",
      "description": "Generic numeric variable 3",
      "role": "candidate_cause"
    },
    "x4": {
